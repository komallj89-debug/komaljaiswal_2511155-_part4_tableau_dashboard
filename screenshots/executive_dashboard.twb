      <aliases enabled='yes' />
      <column caption='Profit Margin' datatype='real' name='[Calculation_1692440946421760]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[profit] / [sales]' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_1692440947007489]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[sales] - [profit]' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_1692440947286018]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) / COUNTD([order_id])' />
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation_1692440947376131]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([return_flag])' />
      </column>
      <column caption='Shipping Delay Bucket' datatype='string' name='[Calculation_1692440947429380]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days] &lt;= 2 THEN &quot;0-2 Days (Fast)&quot; ELSEIF [delivery_days] &lt;= 5 THEN &quot;3-5 Days (Normal)&quot; ELSE &quot;6+ Days (Delayed)&quot; END' />
      </column>
